<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BlockedTails — Live Flight Intelligence</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#080d18;--bg2:#0d1424;--card:#111827;--card2:#1a2540;
  --accent:#3b82f6;--red:#ef4444;--green:#22c55e;
  --yellow:#f59e0b;--purple:#a855f7;
  --text:#e2e8f0;--muted:#64748b;--border:#1e2d45;
  --sidebar:340px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Inter',sans-serif;background:var(--bg);color:var(--text);height:100vh;overflow:hidden;display:flex;flex-direction:column}

/* NAV */
nav{height:52px;background:rgba(8,13,24,.98);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0;z-index:2000}
.logo{display:flex;align-items:center;gap:8px}
.logo-mark{background:linear-gradient(135deg,#3b82f6,#6366f1);border-radius:7px;width:29px;height:29px;display:flex;align-items:center;justify-content:center;font-size:14px}
.logo-name{font-size:16px;font-weight:800;background:linear-gradient(135deg,#fff,#94a3b8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.5px}
.search-wrap{flex:1;max-width:360px;display:flex;gap:6px}
.search-wrap input{flex:1;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:7px 12px;color:var(--text);font-size:12px;outline:none;transition:.2s}
.search-wrap input:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(59,130,246,.15)}
.search-wrap input::placeholder{color:var(--muted)}
.nbtn{background:var(--accent);border:none;border-radius:7px;padding:7px 13px;color:#fff;font-size:12px;font-weight:600;cursor:pointer}
.nbtn:hover{background:#2563eb}
.nav-right{display:flex;align-items:center;gap:6px;margin-left:auto}
.pill{display:flex;align-items:center;gap:5px;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:4px 11px;font-size:11px;font-weight:500}
.dot{width:7px;height:7px;border-radius:50%}
.dot.blue{background:var(--accent);animation:blink 2s infinite}
.dot.red{background:var(--red);animation:blink 1.5s infinite}
.dot.green{background:var(--green)}
.dot.yellow{background:var(--yellow)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.mode-btns{display:flex;background:var(--card);border:1px solid var(--border);border-radius:7px;overflow:hidden}
.mode-btn{padding:5px 10px;font-size:11px;font-weight:500;cursor:pointer;border:none;background:none;color:var(--muted);transition:.15s}
.mode-btn.on{background:var(--accent);color:#fff}

/* LAYOUT */
.main{display:flex;flex:1;overflow:hidden}

/* SIDEBAR */
.sidebar{width:var(--sidebar);background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.sb-head{padding:10px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.sb-title{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.8px}
.tabs{display:flex;gap:3px}
.tab{padding:3px 9px;border-radius:5px;font-size:10px;font-weight:600;cursor:pointer;border:none;background:none;color:var(--muted);text-transform:uppercase;letter-spacing:.3px}
.tab.on{background:var(--accent);color:#fff}
.tab:hover:not(.on){background:var(--card);color:var(--text)}
.list{flex:1;overflow-y:auto;padding:6px}
.list::-webkit-scrollbar{width:3px}
.list::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 11px;margin-bottom:5px;cursor:pointer;transition:all .15s;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.card.commercial::before{background:var(--accent)}
.card.military::before{background:var(--yellow)}
.card.blocked::before{background:var(--red)}
.card.private::before{background:var(--purple)}
.card:hover{border-color:rgba(59,130,246,.4);transform:translateX(2px);background:var(--card2)}
.card.sel{border-color:var(--accent);background:var(--card2);box-shadow:0 0 0 1px rgba(59,130,246,.2)}
.card-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.ac-cs{font-size:14px;font-weight:700;letter-spacing:.2px;display:flex;align-items:center;gap:5px}
.badge{padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;letter-spacing:.5px}
.badge.blk{background:rgba(239,68,68,.15);color:var(--red);border:1px solid rgba(239,68,68,.3)}
.badge.mil{background:rgba(245,158,11,.15);color:var(--yellow);border:1px solid rgba(245,158,11,.3)}
.ac-icao{font-size:10px;color:var(--muted);font-family:monospace}
.card-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
.sbox{background:var(--bg);border-radius:5px;padding:5px 6px}
.slbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px}
.sval{font-size:11px;font-weight:600;margin-top:1px}
.verify-link{font-size:9px;color:var(--muted);text-decoration:none;display:block;margin-top:5px;text-align:right}
.verify-link:hover{color:var(--accent)}

/* MAP */
.map-wrap{flex:1;position:relative}
#map{width:100%;height:100%}

/* MAP OVERLAYS */
.map-top-left{position:absolute;top:12px;left:12px;z-index:900;display:flex;gap:6px;align-items:center}
.map-top-right{position:absolute;top:12px;right:12px;z-index:900;display:flex;flex-direction:column;gap:5px}
.map-btn{background:rgba(8,13,24,.92);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:7px;padding:7px 12px;color:var(--text);font-size:11px;font-weight:500;cursor:pointer;transition:.15s;text-align:left}
.map-btn:hover{border-color:var(--accent);color:var(--accent)}
.map-btn.on{border-color:var(--accent);color:var(--accent);background:rgba(59,130,246,.08)}
.status-badge{background:rgba(8,13,24,.92);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:11px;display:flex;align-items:center;gap:6px;font-weight:500}

/* DEMO BANNER */
.demo-banner{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.3);border-radius:7px;padding:6px 12px;font-size:11px;color:var(--yellow);display:flex;align-items:center;gap:6px}

/* DETAIL PANEL */
.detail{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);background:rgba(8,13,24,.97);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:14px;padding:16px 20px;min-width:500px;max-width:620px;z-index:900;display:none;box-shadow:0 24px 64px rgba(0,0,0,.7)}
.detail.on{display:block;animation:slideUp .2s cubic-bezier(.34,1.56,.64,1)}
@keyframes slideUp{from{opacity:0;transform:translateX(-50%) translateY(16px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.d-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.d-call{font-size:22px;font-weight:800;letter-spacing:-.5px}
.d-sub{font-size:11px;color:var(--muted);margin-top:3px}
.d-close{background:var(--card);border:1px solid var(--border);border-radius:6px;width:28px;height:28px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;color:var(--muted)}
.d-close:hover{color:var(--text)}
.d-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;margin-bottom:8px}
.d-grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:8px}
.dstat{background:var(--card);border-radius:8px;padding:9px 10px;text-align:center}
.dstat-l{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
.dstat-v{font-size:14px;font-weight:700}
.d-source{font-size:10px;color:var(--muted);text-align:right;margin-top:4px}
.d-source a{color:var(--accent);text-decoration:none}
.d-source a:hover{text-decoration:underline}
.d-note{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:7px;padding:7px 10px;font-size:10px;color:var(--yellow);margin-bottom:8px;display:none}
.d-note.on{display:block}
.trail-info{background:var(--card);border-radius:7px;padding:7px 10px;font-size:10px;color:var(--muted)}

/* LEGEND */
.legend{position:absolute;bottom:20px;right:12px;background:rgba(8,13,24,.92);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:10px;padding:10px 14px;z-index:800}
.leg-title{font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:7px}
.leg-row{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--muted);margin-bottom:4px}
.leg-arrow{font-size:12px;line-height:1}

/* OVERLAY */
.overlay{position:absolute;inset:0;background:rgba(8,13,24,.93);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:1500;transition:opacity .4s}
.spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .75s linear infinite;margin-bottom:14px}
@keyframes spin{to{transform:rotate(360deg)}}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--card);border:1px solid var(--border);border-radius:8px;padding:10px 18px;font-size:12px;font-weight:500;z-index:9999;transition:transform .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.ok{border-color:var(--green);color:var(--green)}
.toast.err{border-color:var(--red);color:var(--red)}
.toast.info{border-color:var(--accent);color:var(--accent)}

.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:160px;color:var(--muted);text-align:center;gap:6px;font-size:12px}

/* Leaflet tooltip */
.tip{background:rgba(8,13,24,.95)!important;border:1px solid #1e2d45!important;color:#e2e8f0!important;font-size:11px!important;padding:4px 8px!important;border-radius:6px!important;box-shadow:0 4px 12px rgba(0,0,0,.4)!important}
.tip::before{display:none!important}
</style>
</head>
<body>

<nav>
  <div class="logo">
    <div class="logo-mark">✈</div>
    <span class="logo-name">BlockedTails</span>
  </div>
  <div class="search-wrap">
    <input id="searchInput" type="text" placeholder="Search tail # or callsign (e.g. N280PH)..." autocomplete="off" spellcheck="false">
    <button class="nbtn" onclick="doSearch()">Find</button>
  </div>
  <div class="nav-right">
    <div class="mode-btns">
      <button class="mode-btn on" onclick="setMode('map',this)">Map</button>
      <button class="mode-btn" onclick="setMode('heat',this)">Heatmap</button>
    </div>
    <div class="pill"><div class="dot blue"></div><span id="navTotal">0</span> live</div>
    <div class="pill"><div class="dot red"></div><span id="navBlocked">0</span> blocked</div>
    <div class="pill"><div class="dot yellow"></div><span id="navMil">0</span> military</div>
    <div class="pill"><div class="dot green"></div>LIVE</div>
  </div>
</nav>

<div class="main">
  <div class="sidebar">
    <div class="sb-head">
      <span class="sb-title">Aircraft Feed</span>
      <div class="tabs">
        <button class="tab on" onclick="setFilter('all',this)">All</button>
        <button class="tab" onclick="setFilter('blocked',this)">🔴 Blocked</button>
        <button class="tab" onclick="setFilter('military',this)">🟡 Military</button>
      </div>
    </div>
    <div class="list" id="list"></div>
  </div>

  <div class="map-wrap">
    <div id="map"></div>

    <div class="map-top-left">
      <div class="status-badge" id="statusBadge"><span id="statusText">Connecting...</span></div>
      <div class="demo-banner" id="demoBanner" style="display:none">⚠ Demo mode — add API key for real data</div>
    </div>

    <div class="map-top-right">
      <button class="map-btn" onclick="resetView()">🌍 Reset View</button>
      <button class="map-btn on" id="trailBtn" onclick="toggleTrails()">〰 Trails: ON</button>
      <button class="map-btn" id="tileBtn" onclick="toggleTile()">🛰 Satellite</button>
      <button class="map-btn" onclick="refreshNow()">🔄 Refresh Now</button>
    </div>

    <div class="legend">
      <div class="leg-title">Legend</div>
      <div class="leg-row"><span class="leg-arrow" style="color:#3b82f6">▲</span>Commercial</div>
      <div class="leg-row"><span class="leg-arrow" style="color:#ef4444">▲</span>Blocked Tail</div>
      <div class="leg-row"><span class="leg-arrow" style="color:#f59e0b">▲</span>Military</div>
      <div class="leg-row"><span class="leg-arrow" style="color:#a855f7">▲</span>Private/VIP</div>
      <div style="border-top:1px solid var(--border);margin:6px 0;font-size:9px;color:var(--muted)">Arrow points in direction of travel</div>
    </div>

    <!-- Detail panel -->
    <div class="detail" id="detail">
      <div class="d-head">
        <div>
          <div class="d-call" id="dCall">—</div>
          <div class="d-sub" id="dSub">—</div>
        </div>
        <div class="d-close" onclick="closeDetail()">✕</div>
      </div>
      <div class="d-note" id="dNote"></div>
      <div class="d-grid">
        <div class="dstat"><div class="dstat-l">Altitude</div><div class="dstat-v" id="dAlt">—</div></div>
        <div class="dstat"><div class="dstat-l">Speed</div><div class="dstat-v" id="dSpd">—</div></div>
        <div class="dstat"><div class="dstat-l">Heading</div><div class="dstat-v" id="dHdg">—</div></div>
        <div class="dstat"><div class="dstat-l">Vert Rate</div><div class="dstat-v" id="dVsi">—</div></div>
        <div class="dstat"><div class="dstat-l">Squawk</div><div class="dstat-v" id="dSqk">—</div></div>
      </div>
      <div class="d-grid3">
        <div class="dstat"><div class="dstat-l">ICAO Hex</div><div class="dstat-v" style="font-size:12px;font-family:monospace" id="dIcao">—</div></div>
        <div class="dstat"><div class="dstat-l">Latitude</div><div class="dstat-v" style="font-size:12px" id="dLat">—</div></div>
        <div class="dstat"><div class="dstat-l">Longitude</div><div class="dstat-v" style="font-size:12px" id="dLon">—</div></div>
      </div>
      <div class="trail-info" id="trailInfo">〰 Trail data accumulates every 30s refresh</div>
      <div class="d-source">Source: ADS-B Exchange · <a id="dVerify" href="#" target="_blank">Verify on globe.adsbexchange.com ↗</a></div>
    </div>

    <div class="overlay" id="overlay">
      <div class="spinner"></div>
      <div style="font-size:13px;color:var(--muted);font-weight:500">Loading live ADS-B data...</div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ════════════════════════════════════════════════════
// CONFIG — replace YOUR_ADSB_KEY with your real key
// ════════════════════════════════════════════════════
const ADSB_KEY  = '0b616e6bb7msh7bca2a9c0b72d5ap18774bjsna04e271b0aca';
const ADSB_HOST = 'adsbexchange-com1.p.rapidapi.com';

// Known blocked tails — add more as discovered
const BLOCKED_TAILS = new Set([
  'N280PH','N900SK','N1SP','N2SP','N3SP',
  'N4SP','N5SP','N8PH','N168PH','N170PH',
]);

// Military callsign prefixes (FAA/ICAO standard)
const MIL_PREFIXES = [
  'RCH','RRR','JAKE','DUKE','REACH','EVAC','PAT',
  'SAM','TOUGH','KNIFE','ATLAS','DARK','GHOST','VADER',
  'HOOK','IRON','STEEL','SPAR','MAGMA','ROCKY','FLASH',
  'ZEUS','BOXER','RACER','RAVEN','EAGLE','HAWK',
];

// US DoD ICAO hex ranges (official FAA allocations)
const MIL_ICAO_RANGES = [
  [0xAE0000, 0xAEFFFF], // US Military
  [0xA00000, 0xA003FF], // US Gov special
];

const REFRESH_MS = 30000;
const MAX_TRAIL  = 15;

// ════════════════════════════════════════════════════
// MAP
// ════════════════════════════════════════════════════
const map = L.map('map', {zoomControl:false, preferCanvas:true}).setView([39.5, -98.5], 5);

const TILES = {
  dark: L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {attribution:'© CartoDB © OSM',maxZoom:19}),
  sat:  L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {attribution:'© Esri',maxZoom:19}),
};
TILES.dark.addTo(map);
L.control.zoom({position:'bottomleft'}).addTo(map);

let usingSat = false;
function toggleTile(){
  usingSat = !usingSat;
  if(usingSat){ map.removeLayer(TILES.dark); TILES.sat.addTo(map); document.getElementById('tileBtn').textContent = '🌙 Dark Map'; }
  else { map.removeLayer(TILES.sat); TILES.dark.addTo(map); document.getElementById('tileBtn').textContent = '🛰 Satellite'; }
}

// ════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════
let aircraft  = new Map(); // icao -> ac
let trails    = new Map(); // icao -> [[lat,lon],...]
let markers   = new Map();
let trailLines= new Map();
let heatLayer = null;
let selected  = null;
let filter    = 'all';
let showTrails= true;
let viewMode  = 'map';
let isDemo    = false;

// ════════════════════════════════════════════════════
// CLASSIFY — deterministic, based on fixed ICAO + callsign
// ════════════════════════════════════════════════════
function classify(ac){
  const cs    = (ac.flight || '').trim().toUpperCase();
  const icao  = (ac.icao   || '').toUpperCase();
  const icaoN = parseInt(ac.icao, 16) || 0;

  if(BLOCKED_TAILS.has(cs) || BLOCKED_TAILS.has(icao)) return 'blocked';
  if(MIL_PREFIXES.some(p => cs.startsWith(p)))         return 'military';
  if(MIL_ICAO_RANGES.some(([lo,hi]) => icaoN>=lo && icaoN<=hi)) return 'military';
  // N-number (US registered private/charter — starts N then digit)
  if(/^N[0-9]/.test(cs) && cs.length <= 7)            return 'private';
  return 'commercial';
}

const COLORS = {blocked:'#ef4444', military:'#f59e0b', private:'#a855f7', commercial:'#3b82f6'};

// ════════════════════════════════════════════════════
// ARROW ICON — simple triangle, rotates with heading
// Stays consistent: same ICAO = same color always
// ════════════════════════════════════════════════════
function makeArrow(type, heading, isSelected){
  const color = COLORS[type];
  const h = heading || 0;
  const size = isSelected ? 20 : 14;
  const glow = isSelected ? `drop-shadow(0 0 6px ${color})` : type === 'blocked' ? `drop-shadow(0 0 4px ${color})` : 'none';

  // Pure triangle arrow — nothing random, nothing fancy
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 20 20"
    style="transform:rotate(${h}deg);filter:${glow};display:block">
    <polygon points="10,1 16,17 10,13 4,17" fill="${color}" stroke="${color === '#ef4444' ? '#fff' : 'none'}" stroke-width="${type==='blocked'?'.5':'0'}"/>
  </svg>`;

  return L.divIcon({
    html: svg,
    iconSize: [size, size],
    iconAnchor: [size/2, size/2],
    className: '',
  });
}

// ════════════════════════════════════════════════════
// FETCH
// ════════════════════════════════════════════════════
async function fetchData(){
  setStatus('Fetching...', true);
  try{
    const r = await fetch(`https://${ADSB_HOST}/v2/lat/39.5/lon/-98.5/dist/500/`, {
      headers: {'x-rapidapi-key': ADSB_KEY, 'x-rapidapi-host': ADSB_HOST}
    });
    if(!r.ok) throw new Error(r.status);
    const d = await r.json();
    isDemo = false;
    document.getElementById('demoBanner').style.display = 'none';
    ingestAircraft(d.ac || []);
    setStatus(`${aircraft.size.toLocaleString()} aircraft · ${new Date().toLocaleTimeString()}`, false);
    toast(`✅ ${aircraft.size} live aircraft loaded`, 'ok');
  } catch(e){
    if(aircraft.size === 0){
      isDemo = true;
      document.getElementById('demoBanner').style.display = 'flex';
      loadStaticDemo();
      setStatus('Demo mode — API key needed for live data', false);
    } else {
      setStatus(`Refresh failed · showing last data · ${new Date().toLocaleTimeString()}`, false);
    }
  }
  renderAll();
  hideOverlay();
}

// Ingest real data — deduplicate strictly by ICAO hex
function ingestAircraft(raw){
  const seen = new Set();
  raw.forEach(ac => {
    if(!ac.lat || !ac.lon || !ac.icao) return;
    const icao = ac.icao.toUpperCase().trim();
    if(seen.has(icao)) return;
    seen.add(icao);

    // Update trail — only append if position actually changed
    if(!trails.has(icao)) trails.set(icao, []);
    const trail = trails.get(icao);
    const last = trail[trail.length - 1];
    const moved = !last || Math.abs(last[0]-ac.lat)>0.001 || Math.abs(last[1]-ac.lon)>0.001;
    if(moved) trail.push([ac.lat, ac.lon]);
    if(trail.length > MAX_TRAIL) trail.shift();

    aircraft.set(icao, {
      ...ac,
      icao,
      _type: classify(ac),
      // Normalize fields
      flight: (ac.flight || '').trim(),
      alt_baro: typeof ac.alt_baro === 'number' ? ac.alt_baro : null,
      gs: typeof ac.gs === 'number' ? ac.gs : null,
      track: typeof ac.track === 'number' ? ac.track : null,
    });
  });
}

// Static demo — fixed positions, clearly marked, no randomness
function loadStaticDemo(){
  const DEMO = [
    // Real-world example positions (approximate public info)
    {icao:'A94A2E',flight:'DAL1234',lat:33.64,lon:-84.43,alt_baro:2500,  gs:180,track:270,squawk:'2341',_demo:true},
    {icao:'A6E043',flight:'UAL388', lat:41.97,lon:-87.90,alt_baro:32000, gs:488,track:95, squawk:'4512',_demo:true},
    {icao:'A3C285',flight:'AAL1128',lat:32.84,lon:-96.85,alt_baro:36000, gs:510,track:50, squawk:'6700',_demo:true},
    {icao:'AAAAAA',flight:'N280PH', lat:38.85,lon:-77.04,alt_baro:4500,  gs:165,track:185,squawk:'7700',_demo:true},
    {icao:'AE01F8',flight:'RCH445', lat:36.23,lon:-115.2, alt_baro:31000, gs:440,track:310,squawk:'5173',_demo:true},
    {icao:'AE1234',flight:'JAKE01', lat:29.53,lon:-98.47, alt_baro:8000,  gs:280,track:200,squawk:'0077',_demo:true},
    {icao:'BBBBBB',flight:'N900SK', lat:47.44,lon:-122.3, alt_baro:3200,  gs:150,track:135,squawk:'1234',_demo:true},
    {icao:'A12345',flight:'SWA2112',lat:25.79,lon:-80.28, alt_baro:40000, gs:530,track:340,squawk:'3315',_demo:true},
    {icao:'A23456',flight:'FDX001', lat:35.04,lon:-89.97, alt_baro:22000, gs:380,track:60, squawk:'4321',_demo:true},
    {icao:'AE5678',flight:'ARMY01', lat:38.72,lon:-76.50, alt_baro:5000,  gs:200,track:275,squawk:'7600',_demo:true},
    {icao:'A34567',flight:'N1SP',   lat:40.63,lon:-73.78, alt_baro:1800,  gs:95, track:90, squawk:'0000',_demo:true},
    {icao:'A45678',flight:'UPS2340',lat:37.62,lon:-122.4, alt_baro:18000, gs:320,track:125,squawk:'2200',_demo:true},
    {icao:'A56789',flight:'JBU429', lat:42.36,lon:-71.00, alt_baro:28000, gs:410,track:220,squawk:'4401',_demo:true},
    {icao:'A67890',flight:'SKW3456',lat:45.59,lon:-122.6, alt_baro:15000, gs:290,track:180,squawk:'3302',_demo:true},
    {icao:'AE9ABC',flight:'DUKE12', lat:35.21,lon:-80.94, alt_baro:12000, gs:350,track:100,squawk:'5200',_demo:true},
  ];
  ingestAircraft(DEMO);
}

// ════════════════════════════════════════════════════
// RENDER
// ════════════════════════════════════════════════════
function renderAll(){
  viewMode === 'heat' ? renderHeatmap() : renderMarkers();
  renderList();
  updatePills();
}

function getFiltered(){
  const all = [...aircraft.values()];
  if(filter === 'blocked')  return all.filter(a => a._type === 'blocked');
  if(filter === 'military') return all.filter(a => a._type === 'military');
  return all;
}

function renderMarkers(){
  markers.forEach(m => map.removeLayer(m));
  markers.clear();
  trailLines.forEach(l => map.removeLayer(l));
  trailLines.clear();
  if(heatLayer){ map.removeLayer(heatLayer); heatLayer = null; }

  getFiltered().forEach(ac => {
    const isSel = ac.icao === selected;

    // Draw trail first (so it's behind the marker)
    if(showTrails){
      const trail = trails.get(ac.icao) || [];
      if(trail.length > 1){
        const line = L.polyline(trail.map(p => L.latLng(p[0], p[1])), {
          color: COLORS[ac._type],
          weight: isSel ? 2 : 1,
          opacity: isSel ? 0.85 : ac._type === 'blocked' ? 0.6 : 0.3,
          dashArray: ac._type === 'military' ? '5,4' : null,
        }).addTo(map);
        trailLines.set(ac.icao, line);
      }
    }

    // Marker — arrow icon
    const m = L.marker([ac.lat, ac.lon], {
      icon: makeArrow(ac._type, ac.track, isSel),
      zIndexOffset: ac._type === 'blocked' ? 1000 : isSel ? 500 : 0,
    });

    const cs = ac.flight || ac.icao;
    m.bindTooltip(`<b>${cs}</b>  ${ac._type.toUpperCase()}<br>${ac.alt_baro ? Math.round(ac.alt_baro).toLocaleString()+' ft' : ''}${ac.gs ? '  ·  '+Math.round(ac.gs)+' kt' : ''}`,
      {className:'tip', direction:'top', offset:[0,-4]});
    m.on('click', () => selectAc(ac.icao));
    m.addTo(map);
    markers.set(ac.icao, m);
  });
}

function renderHeatmap(){
  markers.forEach(m => map.removeLayer(m));
  markers.clear();
  trailLines.forEach(l => map.removeLayer(l));
  trailLines.clear();
  if(heatLayer) map.removeLayer(heatLayer);

  const pts = getFiltered().map(ac => [
    ac.lat, ac.lon,
    ac._type==='blocked' ? 1.0 : ac._type==='military' ? 0.8 : 0.4
  ]);

  heatLayer = L.heatLayer(pts, {
    radius:30, blur:20, maxZoom:9,
    gradient:{0.2:'#3b82f6', 0.5:'#f59e0b', 0.8:'#ef4444', 1.0:'#fff'}
  }).addTo(map);
}

function renderList(){
  const el = document.getElementById('list');
  const items = [...getFiltered()].sort((a,b) => {
    const o = {blocked:0, military:1, private:2, commercial:3};
    if(o[a._type] !== o[b._type]) return o[a._type] - o[b._type];
    return (b.alt_baro||0) - (a.alt_baro||0);
  });

  if(!items.length){
    el.innerHTML = '<div class="empty"><div>📡</div><div>No aircraft</div></div>';
    return;
  }

  el.innerHTML = items.map(ac => {
    const cs = ac.flight || ac.icao || '???';
    const isSel = ac.icao === selected;
    const altStr = ac.alt_baro != null ? `${(Math.round(ac.alt_baro/100)*100).toLocaleString()} ft` : '—';
    const spdStr = ac.gs != null ? `${Math.round(ac.gs)} kt` : '—';
    const hdgStr = ac.track != null ? `${Math.round(ac.track)}°` : '—';
    const badge  = ac._type==='blocked' ? '<span class="badge blk">BLOCKED</span>'
                 : ac._type==='military' ? '<span class="badge mil">MIL</span>' : '';
    const altColor = ac.alt_baro > 30000 ? 'var(--green)' : ac.alt_baro > 10000 ? 'var(--yellow)' : 'var(--red)';

    return `<div class="card ${ac._type} ${isSel?'sel':''}" onclick="selectAc('${ac.icao}')">
      <div class="card-row">
        <div class="ac-cs">${cs} ${badge}</div>
        <div class="ac-icao">${ac.icao}${ac._demo?' · DEMO':''}</div>
      </div>
      <div class="card-stats">
        <div class="sbox"><div class="slbl">Alt</div><div class="sval" style="color:${altColor}">${altStr}</div></div>
        <div class="sbox"><div class="slbl">Speed</div><div class="sval">${spdStr}</div></div>
        <div class="sbox"><div class="slbl">Heading</div><div class="sval">${hdgStr}</div></div>
      </div>
      <a class="verify-link" href="https://globe.adsbexchange.com/?icao=${ac.icao.toLowerCase()}" target="_blank">Verify on ADS-B Exchange ↗</a>
    </div>`;
  }).join('');
}

function updatePills(){
  const all = [...aircraft.values()];
  document.getElementById('navTotal').textContent   = all.length.toLocaleString();
  document.getElementById('navBlocked').textContent = all.filter(a=>a._type==='blocked').length;
  document.getElementById('navMil').textContent     = all.filter(a=>a._type==='military').length;
}

// ════════════════════════════════════════════════════
// SELECT
// ════════════════════════════════════════════════════
function selectAc(icao){
  const ac = aircraft.get(icao);
  if(!ac) return;
  selected = icao;
  map.flyTo([ac.lat, ac.lon], Math.max(map.getZoom(), 8), {duration:.8});

  const cs = ac.flight || ac.icao;
  const color = COLORS[ac._type];

  document.getElementById('dCall').textContent = cs;
  document.getElementById('dCall').style.color = ac._type==='blocked' ? 'var(--red)' : ac._type==='military' ? 'var(--yellow)' : 'var(--text)';
  document.getElementById('dSub').innerHTML = `ICAO: <b style="font-family:monospace">${ac.icao}</b> &nbsp;·&nbsp; Type: <b style="color:${color}">${ac._type.toUpperCase()}</b> &nbsp;·&nbsp; Squawk: <b>${ac.squawk||'—'}</b>`;
  document.getElementById('dAlt').textContent = ac.alt_baro != null ? `${Math.round(ac.alt_baro).toLocaleString()} ft` : '—';
  document.getElementById('dSpd').textContent = ac.gs != null ? `${Math.round(ac.gs)} kt` : '—';
  document.getElementById('dHdg').textContent = ac.track != null ? `${Math.round(ac.track)}°` : '—';
  document.getElementById('dVsi').textContent = ac.baro_rate ? `${ac.baro_rate>0?'+':''}${Math.round(ac.baro_rate)} fpm` : '—';
  document.getElementById('dSqk').textContent = ac.squawk || '—';
  document.getElementById('dIcao').textContent = ac.icao;
  document.getElementById('dLat').textContent  = ac.lat ? ac.lat.toFixed(5) : '—';
  document.getElementById('dLon').textContent  = ac.lon ? ac.lon.toFixed(5) : '—';

  const trail = trails.get(icao) || [];
  document.getElementById('trailInfo').textContent =
    trail.length > 1 ? `〰 ${trail.length} trail positions · refreshes every 30s` : '〰 Trail accumulating...';

  // Demo note
  const note = document.getElementById('dNote');
  if(ac._demo){
    note.textContent = '⚠ This is demo data for illustration. Add your API key to see real live aircraft.';
    note.classList.add('on');
  } else {
    note.classList.remove('on');
  }

  // Verify link
  document.getElementById('dVerify').href = `https://globe.adsbexchange.com/?icao=${icao.toLowerCase()}`;

  document.getElementById('detail').classList.add('on');
  renderMarkers(); // re-render to highlight selected
}

function closeDetail(){
  selected = null;
  document.getElementById('detail').classList.remove('on');
  renderMarkers();
  renderList();
}

// ════════════════════════════════════════════════════
// SEARCH
// ════════════════════════════════════════════════════
function doSearch(){
  const q = document.getElementById('searchInput').value.trim().toUpperCase();
  if(!q) return;

  // Exact match first, then partial
  let match = null;
  for(const [,ac] of aircraft){
    const cs   = (ac.flight||'').toUpperCase();
    const icao = (ac.icao||'').toUpperCase();
    if(cs===q || icao===q){ match=ac; break; }
    if(!match && (cs.includes(q) || icao.includes(q))) match=ac;
  }

  if(match){
    selectAc(match.icao);
    const type = match._type;
    toast(`✈ ${(match.flight||match.icao)} · ${type.toUpperCase()}${match._demo?' (demo)':''}`,
      type==='blocked'?'err':type==='military'?'info':'ok');
  } else {
    toast(`Not found: "${q}" — may be outside range or not currently airborne`, 'err');
  }
}

document.getElementById('searchInput').addEventListener('keydown', e => e.key==='Enter' && doSearch());

// ════════════════════════════════════════════════════
// CONTROLS
// ════════════════════════════════════════════════════
function setFilter(f, btn){
  filter = f;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
  btn.classList.add('on');
  closeDetail();
  renderAll();
}

function setMode(m, btn){
  viewMode = m;
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  renderAll();
}

function toggleTrails(){
  showTrails = !showTrails;
  const btn = document.getElementById('trailBtn');
  btn.textContent = `〰 Trails: ${showTrails?'ON':'OFF'}`;
  btn.classList.toggle('on', showTrails);
  renderMarkers();
}

function resetView(){ map.flyTo([39.5,-98.5], 5, {duration:1}); }
function refreshNow(){ fetchData(); toast('🔄 Refreshing data...','info'); }

function setStatus(txt, loading){
  document.getElementById('statusBadge').innerHTML = loading
    ? `<span style="display:inline-block;width:9px;height:9px;border:2px solid #1e2d45;border-top-color:var(--accent);border-radius:50%;animation:spin .75s linear infinite"></span><span style="color:var(--muted)">${txt}</span>`
    : `<span style="color:var(--green)">●</span><span>${txt}</span>`;
}

function hideOverlay(){
  const o = document.getElementById('overlay');
  o.style.opacity = '0';
  setTimeout(() => o.style.display='none', 400);
}

let toastT;
function toast(msg, type='info'){
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast ${type} show`;
  clearTimeout(toastT); toastT = setTimeout(() => t.classList.remove('show'), 3500);
}

// ════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════
fetchData();
setInterval(fetchData, REFRESH_MS);
</script>
</body>
</html>
